MONGODB_URI=mongodb://127.0.0.1:27017/tap_tap
JWT_SECRET=replace_with_secure_secret
PORT=3000

# Gmail SMTP (signup welcome email). Use an App Password, not your normal password.
# File must live next to package.json. Keys are case-sensitive (use UPPERCASE as below).
# Aliases also work: SMTP_USER + SMTP_PASS, or GMAIL_APP_PASSWORD instead of APP_PASSWORD.
GMAIL=your.address@gmail.com
APP_PASSWORD=your_16_char_app_password

# Optional display name in the From header
# MAIL_FROM_NAME=Tap Tap
